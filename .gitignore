# Generados por bootstrap.sh a partir de templates/ (rutas absolutas por máquina)
/config.kdl
/layouts/main.kdl
/layouts/dev.kdl
/permissions.kdl

# Plugins descargados por bootstrap.sh (versiones fijas en el manifest)
/plugins/*.wasm

# Override por-host del agente del layout dev (ver scripts/agent.sh)
/agent.local

# Backups locales y cruft
*.bak
.claude/
